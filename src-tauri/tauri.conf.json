{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shiro",
  "version": "0.1.0",
  "identifier": "com.adityaapkumar.shiro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Shiro",
        "url": "/",
        "width": 720,
        "height": 560,
        "resizable": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "Shiro Overlay",
        "url": "/#/overlay",
        "width": 340,
        "height": 480,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": false,
        "x": 40,
        "y": 40,
        "transparent": true,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
