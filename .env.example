# Copy to .env and fill in your real values — never commit .env to git.
# You can also switch providers at runtime via the Settings UI.
ANTHROPIC_API_KEY=sk-ant-...

OPENAI_API_KEY=sk-...
# Optional: override the OpenAI base URL (Azure, Ollama, LM Studio, etc.)
# Defaults to https://api.openai.com/v1 if not set
OPENAI_BASE_URL=https://api.openai.com/v1
